.pytest_cache/
.tox/
.nox/
.mypy_cache/
.cache/

# IDEs / editors
.vscode/
.idea/
*.sublime-*
*.swp

# OS files
.DS_Store

# Logs and databases
*.log
*.sqlite3

# Project metadata
openenv_construction_env.egg-info/

# Git
.git
.gitignore
